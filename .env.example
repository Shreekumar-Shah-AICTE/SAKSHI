# =============================================================================
# SAKSHI — environment manifest
# =============================================================================
# THE GOLDEN PATH NEEDS ZERO SECRETS.
# Every value below is OPTIONAL "progressive enhancement". With none of them
# set, the deployed demo is fully functional on seeded 2025 Churu data and the
# deterministic Gravity Core (hash-chain + corroboration) runs unchanged.
# Each live adapter FAILS CLOSED to seeded data if its key is missing.
# NEVER commit real values — copy this file to `.env.local`.
# =============================================================================

# ---- Supabase (OPTIONAL) — real persistence of receipts/dossiers. -----------
# Without these, SAKSHI uses the in-memory seed store behind the same interface.
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
# Server-side only. NEVER expose this to the browser bundle.
SUPABASE_SERVICE_ROLE_KEY=

# ---- Bhashini (OPTIONAL) — live voice STT/TTS/translate in 22 languages. ----
# Without these, seeded Marwari/Hindi/English translations play from fixtures.
# Server-side only.
BHASHINI_USER_ID=
BHASHINI_API_KEY=
BHASHINI_INFERENCE_API_KEY=

# ---- Copernicus / Sentinel-2 (OPTIONAL) — live NDVI. ------------------------
# Without these, real seeded Sentinel-2 NDVI values for the 5 events are used.
# Server-side only.
COPERNICUS_CLIENT_ID=
COPERNICUS_CLIENT_SECRET=

# ---- Open-Meteo — NO KEY REQUIRED (free, open). -----------------------------
# The live weather adapter calls the public archive API directly; if the
# network is unavailable it fails closed to the real 10-year baseline captured
# in the seed fixtures. No configuration needed.

# ---- App ---------------------------------------------------------------------
# Public base URL used to build QR verification links. Defaults to request host.
NEXT_PUBLIC_APP_URL=
